# =============================================================================
#  Sistema de Automatización IA Hotel — Variables de entorno (PLANTILLA)
# -----------------------------------------------------------------------------
#  Copia este archivo a `.env` y completa los valores reales.
#      cp .env.example .env
#  NUNCA subas el archivo `.env` al repositorio (ya está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
#  Aplicación
# -----------------------------------------------------------------------------
APP_NAME="Sistema Automatizacion IA Hotel"
# development | production
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
# Si es true, al arrancar siembra reservas y vectoriza políticas si faltan.
AUTO_INIT=true

# -----------------------------------------------------------------------------
#  LLM — Groq  (OBLIGATORIO)
#  Crea una API key gratuita en https://console.groq.com/keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_tu_api_key_de_groq_aqui
LLM_MODEL=llama-3.3-70b-versatile
# Temperatura del agente que redacta la respuesta (creativo pero controlado)
LLM_TEMPERATURE=0.3
# Temperatura del extractor estructurado (determinista)
EXTRACTION_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
#  Base de datos — PostgreSQL + pgvector  (OBLIGATORIO)
#  En Docker el host es el nombre del servicio: `db`.
#  En local (sin Docker) usa `localhost`.
#  Formato: postgresql+psycopg://USUARIO:PASSWORD@HOST:PUERTO/BASEDATOS
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://hotel:hotel@db:5432/hoteldb

# Variables usadas por el contenedor oficial de Postgres (docker-compose)
POSTGRES_USER=hotel
POSTGRES_PASSWORD=hotel
POSTGRES_DB=hoteldb

# -----------------------------------------------------------------------------
#  RAG — Embeddings y Vector Store
#  Proveedor de embeddings: huggingface | fastembed | openai
#   - huggingface (def.): multilingüe, offline, sin API key (descarga el modelo)
#   - fastembed: ligero (ONNX, sin torch); cambia el modelo si lo usas
#   - openai: requiere OPENAI_API_KEY
# -----------------------------------------------------------------------------
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
PGVECTOR_COLLECTION=politicas_hotel
RAG_TOP_K=3
POLICIES_DIR=data/policies
# Solo si EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
#  Notificaciones — Telegram  (OPCIONAL: alerta de reclamos críticos)
#  Si se dejan vacías, la función se desactiva con un aviso (no rompe el flujo).
#  Token: habla con @BotFather.  Chat ID: usa @userinfobot o getUpdates.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
#  Correo — SMTP  (OPCIONAL: email de compensación a huéspedes VIP/frecuentes)
#  Si se dejan vacías, la función se desactiva con un aviso (no rompe el flujo).
#  Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal).
#  Desarrollo: se recomienda Mailtrap (https://mailtrap.io) para no enviar real.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM="Dirección de Calidad <calidad@hotel-luxury.com>"
# Destinatario por defecto si la reserva no tiene email registrado.
EMAIL_DEFAULT_TO=

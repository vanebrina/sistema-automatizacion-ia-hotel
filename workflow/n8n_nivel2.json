    {
      "parameters": {
        "description": "\"Útil para consultar la base de datos del hotel. Úsala cuando el huésped mencione su nombre o apellido para verificar si tiene una reserva activa, su número de habitación, los días de estancia o el estado de su pago.\"",
        "jsCode": "// 1. Base de datos simulada del hotel\nconst baseDatosReservas = [\n  { \n    nombre: \"marta gomez\", \n    habitacion: \"204\", \n    noches: 3, \n    estadoPago: \"completado\", \n    tipoCliente: \"vip\" \n  },\n  { \n    nombre: \"carlos mendoza\", \n    habitacion: \"105\", \n    noches: 1, \n    estadoPago: \"completado\", \n    tipoCliente: \"regular\" \n  },\n  { \n    nombre: \"sebastian\", \n    habitacion: \"312\", \n    noches: 5, \n    estadoPago: \"pendiente\", \n    tipoCliente: \"frecuente\" \n  }\n];\n\n// 2. n8n nos pasa lo que la IA quiere buscar en la variable 'query'\nconst busqueda = $input.item.json.input\n  .toLowerCase()\n  .normalize(\"NFD\")\n  .replace(/[\\u0300-\\u036f]/g, \"\")\n  .trim();\n\n// 3. Buscar si el texto que envió la IA coincide con algún huésped\nconst resultado = baseDatosReservas.find(huesped => busqueda.includes(huesped.nombre) || huesped.nombre.includes(busqueda));\n\n// 4. Devolver la respuesta al agente\nif (resultado) {\n  return `Sistema del Hotel: Se encontró reserva activa para ${resultado.nombre.toUpperCase()}. Habitación: ${resultado.habitacion}, Estancia: ${resultado.noches} noches, Pago: ${resultado.estadoPago}, Tipo de Cliente: ${resultado.tipoCliente}.`;\n} else {\n  return `Sistema del Hotel: No se encontró ninguna reserva activa que coincida con el término \"${$input.item.json.input}\".`;\n}"
      },
